{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/ABSOLUTE/PATH/TO/qwen-superpowers/hooks/block-dangerous-bash.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/ABSOLUTE/PATH/TO/qwen-superpowers/hooks/run-checks-after-edit.sh",
            "timeout": 130
          }
        ]
      }
    ]
  }
}
